# Ratatosk Docker Compose Environment Variables
# Copy this file to .env and adjust values for your deployment.

# ─── Server Configuration ───────────────────────────────────────────
# Base domain for tunnel subdomains (requires wildcard DNS: *.tunnel.example.com)
RATATOSK_BASE_DOMAIN=localhost

# Port for the public HTTP(S) proxy (use 443 with TLS in production)
RATATOSK_PUBLIC_PORT=8080

# Port for the admin dashboard and API
RATATOSK_ADMIN_PORT=8081

# Port for the TCP control plane (CLI clients connect here)
RATATOSK_CONTROL_PORT=7000

# TLS Configuration (set to true for production with valid certs)
RATATOSK_TLS_ENABLED=false
RATATOSK_TLS_CERT_FILE=
RATATOSK_TLS_KEY_FILE=

# ─── Client Configuration ───────────────────────────────────────────
# Relay server address for the CLI client (host:port)
RATATOSK_SERVER=tunnel.example.com:7000

# Local port to expose through the tunnel
RATATOSK_PORT=3000

# Optional: HTTP Basic Auth for tunnel visitors (format: user:pass)
RATATOSK_BASIC_AUTH=

# Optional: Enable streamer mode to redact sensitive data from logs
RATATOSK_STREAMER=false
