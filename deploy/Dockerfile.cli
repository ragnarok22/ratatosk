# Stage 1: Build the Go binary
FROM golang:1.26-alpine AS builder
RUN apk add --no-cache git
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-s -w" -o /ratatosk-cli ./cmd/cli

# Stage 2: Minimal runtime image
FROM alpine:3.21
RUN apk add --no-cache ca-certificates \
    && addgroup -S ratatosk && adduser -S ratatosk -G ratatosk
COPY --from=builder /ratatosk-cli /usr/local/bin/ratatosk

USER ratatosk

ENTRYPOINT ["/usr/local/bin/ratatosk"]
